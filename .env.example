# --- MASI source repository (canonical outputs) ---
# Optionnel. Par defaut le RAG cherche ../masi-hybrid-forecasting (a cote du dashboard).
# Ne decommente/edite que si le projet MASI est ailleurs.
# MASI_PROJECT_ROOT=C:/chemin/vers/masi-hybrid-forecasting

# --- API server ---
API_HOST=127.0.0.1
API_PORT=8000

# --- LLM backend ---
# Valeurs possibles : "fallback" (déterministe, pas de réseau), "openai", "anthropic", "ollama"
LLM_BACKEND=fallback

# Si LLM_BACKEND=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Si LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Si LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# --- RAG ---
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_EMBEDDING_DEVICE=cpu
RAG_CHROMA_DIR=./.chroma_db
RAG_COLLECTION=masi_kb
RAG_TOP_K=6
